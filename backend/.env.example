# Backend Environment Variables
PORT=5000

# PostgreSQL Database (local for dev, Supabase/Neon connection string for production)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/rasoi_db

# JWT Secret (change this to a long random string in production)
JWT_SECRET=rasoi_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
